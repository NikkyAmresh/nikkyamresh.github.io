---
import StackTag from '@/components/StackTag.astro';
import PlaceholderVisual from '@/components/PlaceholderVisual.astro';

interface Props {
  title: string;
  tagline: string;
  stack: string[];
  href: string;
  coverSrc?: string;
  coverPlaceholder?: string;
  badge?: string;
}
const { title, tagline, stack, href, coverSrc, coverPlaceholder, badge } = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col gap-4 rounded-lg border border-border bg-surface p-4 no-underline transition hover:border-text-muted"
>
  <div class="relative">
    {
      coverSrc ? (
        <img
          src={coverSrc}
          alt={`${title} preview`}
          loading="lazy"
          class="aspect-[16/10] w-full rounded-md border border-border object-cover"
        />
      ) : (
        <PlaceholderVisual initials={coverPlaceholder ?? title.slice(0, 2).toUpperCase()} />
      )
    }
    {
      badge && (
        <span class="absolute right-2 top-2 rounded-full border border-border bg-bg/90 px-2 py-0.5 font-mono text-2xs uppercase tracking-wider text-text-muted backdrop-blur">
          {badge}
        </span>
      )
    }
  </div>

  <div>
    <h3 class="text-base font-medium text-text transition group-hover:text-accent">
      {title}
      <span class="inline-block translate-x-0 opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100">→</span>
    </h3>
    <p class="mt-1 text-sm leading-relaxed text-text-muted">{tagline}</p>
  </div>

  <div class="mt-auto flex flex-wrap gap-1.5">
    {stack.map((s) => <StackTag label={s} />)}
  </div>
</a>
