---
interface Props {
  label: string;
  title: string;
  id?: string;
}
const { label, title, id } = Astro.props;
---

<div id={id} class="scroll-mt-20">
  <p class="font-mono text-2xs uppercase tracking-[0.18em] text-accent">{label}</p>
  <h2 class="mt-2 text-2xl font-medium tracking-tight sm:text-3xl">{title}</h2>
</div>
