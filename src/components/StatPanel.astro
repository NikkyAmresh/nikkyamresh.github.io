---
interface Stat {
  label: string;
  value: string;
  note?: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---

<dl class="grid grid-cols-2 gap-x-4 gap-y-6 sm:grid-cols-4">
  {
    stats.map((s) => (
      <div class="border-l-2 border-border pl-3 transition hover:border-accent">
        <dt class="font-mono text-2xs uppercase tracking-[0.18em] text-text-subtle">{s.label}</dt>
        <dd class="mt-1 font-mono text-xl text-text sm:text-2xl">{s.value}</dd>
        {s.note && <dd class="mt-0.5 text-xs text-text-muted">{s.note}</dd>}
      </div>
    ))
  }
</dl>
