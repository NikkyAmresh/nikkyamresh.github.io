---
import { site } from '@/lib/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60 mt-16">
  <div class="mx-auto flex max-w-layout flex-col gap-4 px-4 py-6 text-xs text-text-subtle sm:px-6 lg:px-8">
    <nav class="flex flex-wrap gap-x-4 gap-y-2 font-mono">
      <a href="/contact" class="hover:text-text-muted hover:underline">Contact</a>
      <a href="/sponsor" class="hover:text-text-muted hover:underline">Sponsor</a>
      <a href="/refunds" class="hover:text-text-muted hover:underline">Refunds</a>
      <a href="/terms" class="hover:text-text-muted hover:underline">Terms</a>
      <a href="/privacy" class="hover:text-text-muted hover:underline">Privacy</a>
      <a href="/security" class="hover:text-text-muted hover:underline">Security</a>
    </nav>
    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono">
        © {year} {site.name}
      </p>
      <p class="font-mono">
        Built with <a href="https://astro.build" target="_blank" rel="noopener" class="underline hover:text-text-muted">Astro</a>.
        <a href="https://github.com/NikkyAmresh/nikkyamresh.github.io" target="_blank" rel="noopener" class="underline hover:text-text-muted">Source</a>.
      </p>
    </div>
  </div>
</footer>
