---
// Generative SVG placeholder used when a project has no real screenshot yet.
// Varies a little per project based on hash of initials, so cards don't all look identical.

interface Props {
  initials: string;
  className?: string;
}
const { initials, className = '' } = Astro.props;

// Deterministic accent variation per initials
const hash = [...initials].reduce((a, c) => a + c.charCodeAt(0), 0);
const angle = (hash * 37) % 360;
---

<div
  class:list={[
    'relative flex aspect-[16/10] w-full items-center justify-center overflow-hidden rounded-lg border border-border',
    className,
  ]}
>
  <div
    class="absolute inset-0 opacity-80"
    style={`background: conic-gradient(from ${angle}deg at 50% 50%, rgb(var(--color-bg-subtle)), rgb(var(--color-surface)), rgb(var(--color-bg-subtle)));`}
  >
  </div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(59,130,246,0.10),transparent_55%)]"></div>

  <!-- faint grid -->
  <svg
    class="absolute inset-0 h-full w-full opacity-[0.07]"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <pattern id={`grid-${initials}`} width="32" height="32" patternUnits="userSpaceOnUse">
        <path d="M 32 0 L 0 0 0 32" fill="none" stroke="currentColor" stroke-width="1"></path>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill={`url(#grid-${initials})`}></rect>
  </svg>

  <span class="relative z-10 font-mono text-4xl font-medium tracking-tight text-text/80 sm:text-5xl">
    {initials}
  </span>
</div>
