---
import BaseLayout from '@/layouts/BaseLayout.astro';
import StackTag from '@/components/StackTag.astro';
import PlaceholderVisual from '@/components/PlaceholderVisual.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
}
const { entry } = Astro.props;
const { data } = entry;

const linkLabels: Record<string, string> = {
  github: 'GitHub',
  marketplace: 'VS Code Marketplace',
  openvsx: 'Open VSX',
  demo: 'Demo',
};
---

<BaseLayout
  title={data.title}
  description={data.tagline}
>
  <article class="mx-auto max-w-prose px-4 pb-16 pt-8 sm:px-6 sm:pb-20 lg:px-8">
    <!-- Back link -->
    <a
      href="/#projects"
      class="inline-flex items-center gap-1 font-mono text-2xs uppercase tracking-wider text-text-subtle no-underline transition hover:text-text-muted"
    >
      <span>←</span> All projects
    </a>

    <!-- Header -->
    <header class="mt-6">
      <div class="flex items-center gap-2 text-2xs">
        <span class="font-mono uppercase tracking-[0.18em] text-accent">{data.status}</span>
        {data.date && (
          <span class="font-mono text-text-subtle">· {data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</span>
        )}
      </div>
      <h1 class="mt-2 text-3xl font-medium tracking-tight sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-lg leading-relaxed text-text-muted">{data.tagline}</p>

      <!-- Cover -->
      <div class="mt-8">
        {
          data.cover.src ? (
            <img
              src={data.cover.src}
              alt={`${data.title} preview`}
              class="aspect-[16/10] w-full rounded-lg border border-border object-cover"
            />
          ) : (
            <PlaceholderVisual initials={data.cover.placeholder ?? data.title.slice(0, 2).toUpperCase()} />
          )
        }
      </div>

      <!-- Stack + links -->
      <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 border-y border-border/70 py-4">
        <div class="flex flex-wrap gap-1.5">
          {data.stack.map((s) => <StackTag label={s} />)}
        </div>
        {
          Object.entries(data.links).length > 0 && (
            <div class="flex flex-wrap gap-3 text-sm">
              {Object.entries(data.links).map(([k, v]) =>
                v ? (
                  <a
                    href={v}
                    target="_blank"
                    rel="noopener"
                    class="text-accent no-underline transition hover:underline underline-offset-4"
                  >
                    {linkLabels[k] ?? k} →
                  </a>
                ) : null
              )}
            </div>
          )
        }
      </div>
    </header>

    <!-- MDX body -->
    <div class="prose prose-sm mt-10 sm:prose-base">
      <slot />
    </div>
  </article>
</BaseLayout>
