---
import BaseLayout from '@/layouts/BaseLayout.astro';

const channels = [
  { label: 'Email',    value: 'nikkyamresh8@gmail.com', href: 'mailto:nikkyamresh8@gmail.com' },
  { label: 'Phone',    value: '+91 88009 00692',        href: 'tel:+918800900692' },
  { label: 'GitHub',   value: '@NikkyAmresh',           href: 'https://github.com/NikkyAmresh' },
  { label: 'LinkedIn', value: 'nikky-amresh',           href: 'https://linkedin.com/in/nikky-amresh' },
];
---

<BaseLayout
  title="Contact & Support"
  description="Ways to reach Nikky Amresh — email, phone, and social channels for general questions, sponsorship support, and business inquiries."
>
  <article class="mx-auto max-w-prose px-4 pb-20 pt-12 sm:px-6 sm:pt-16 lg:px-8">
    <header>
      <p class="font-mono text-2xs uppercase tracking-[0.18em] text-accent">Contact</p>
      <h1 class="mt-2 text-3xl font-medium tracking-tight sm:text-4xl">
        Get in touch.
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-text-muted">
        Email is the most reliable way to reach me. I usually reply within
        2&ndash;3 business days (IST).
      </p>
    </header>

    <section class="mt-12">
      <p class="font-mono text-2xs uppercase tracking-[0.18em] text-text-subtle">Channels</p>
      <ul class="mt-6 divide-y divide-border border-y border-border">
        {
          channels.map((c) => (
            <li>
              <a
                href={c.href}
                target={c.href.startsWith('http') ? '_blank' : undefined}
                rel={c.href.startsWith('http') ? 'noopener' : undefined}
                class="group flex items-baseline justify-between gap-4 py-3 no-underline transition hover:bg-bg-subtle"
              >
                <span class="text-sm text-text group-hover:text-accent">{c.label}</span>
                <span class="font-mono text-xs text-text-subtle">{c.value}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="prose prose-invert mt-12">
      <h2>Support for sponsors</h2>
      <p>
        If you are a current or prospective sponsor and need help with a
        charge, cancellation, or refund, email
        <a href="mailto:nikkyamresh8@gmail.com">nikkyamresh8@gmail.com</a>
        with the subject line <strong>&ldquo;Sponsorship support&rdquo;</strong>
        and include your GitHub username and the approximate charge date.
        See the <a href="/refunds">refunds policy</a> for what to expect.
      </p>

      <h2>Business address</h2>
      <p>
        Nikky Amresh<br />
        Bangalore, Karnataka, India<br />
        Operating as an individual / sole proprietor.
      </p>
      <p>
        For postal correspondence, please email first &mdash; I&rsquo;ll share
        a current mailing address on request.
      </p>

      <h2>Hours</h2>
      <p>
        Monday&ndash;Friday, 10:00&ndash;19:00 IST (UTC+5:30). Messages
        outside these hours are read on the next business day.
      </p>
    </section>

    <div class="mt-16">
      <a href="/" class="font-mono text-sm text-accent no-underline hover:underline underline-offset-4">
        ← Back to home
      </a>
    </div>
  </article>
</BaseLayout>
